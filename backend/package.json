{
  "name": "chat-app-socket-io",
  "version": "1.0.0",
  "main": "index.js",
  "module": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/database.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts"
  },
  "keywords": [],
  "author": "Nanditha H",
  "license": "ISC",
  "description": "Chat Application using Socket.io",
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}